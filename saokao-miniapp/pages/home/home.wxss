/* ===== 首页完整样式 ===== */

.page {
  width: 100%;
  background: #EEF4FF;
  min-height: 100vh;
  font-family: -apple-system, 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

/* ===== HERO BANNER ===== */
.hero-banner {
  width: 100%;
  height: 720rpx;
  position: relative;
  overflow: hidden;
}

.hero-bg-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.status-bar-placeholder {
  height: var(--status-bar-height, 88rpx);
  position: relative;
  z-index: 5;
}

/* 顶部导航 */
.nav-bar {
  height: 88rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  position: relative;
  z-index: 5;
}

.nav-dots-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 30rpx;
  padding: 12rpx 20rpx;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.9);
}

.nav-circle {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-circle-inner {
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255,255,255,0.7);
}

/* GO GO 装饰文字 */
.go-text {
  position: absolute;
  font-size: 120rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.12);
  letter-spacing: 8rpx;
  z-index: 1;
  pointer-events: none;
}

.go-text-1 {
  top: 120rpx;
  left: -10rpx;
}

.go-text-2 {
  top: 240rpx;
  left: 80rpx;
}

/* 闪光星星 */
.sparkle {
  position: absolute;
  color: rgba(255, 255, 255, 0.75);
  z-index: 3;
  pointer-events: none;
  font-style: normal;
}

.sp-1 {
  font-size: 28rpx;
  top: 180rpx;
  left: 36rpx;
}

.sp-2 {
  font-size: 20rpx;
  top: 280rpx;
  left: 180rpx;
}

.sp-3 {
  font-size: 24rpx;
  top: 160rpx;
  right: 260rpx;
}

.sp-4 {
  font-size: 18rpx;
  top: 320rpx;
  right: 200rpx;
}

/* 装饰星点 */
.deco-star {
  position: absolute;
  border-radius: 50%;
  background: rgba(255,255,255,0.6);
}
.s1 { width: 14rpx; height: 14rpx; top: 200rpx; left: 48rpx; }
.s2 { width: 8rpx; height: 8rpx; top: 250rpx; left: 160rpx; }
.s3 { width: 10rpx; height: 10rpx; top: 310rpx; right: 280rpx; }
.s4 { width: 6rpx; height: 6rpx; top: 180rpx; right: 200rpx; }

/* 背景装饰圆 */
.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
}
.bc1 {
  width: 280rpx;
  height: 280rpx;
  bottom: -80rpx;
  left: -60rpx;
}
.bc2 {
  width: 180rpx;
  height: 180rpx;
  top: 160rpx;
  left: 180rpx;
}

/* 标题文字 */
.hero-text-wrap {
  padding-left: 40rpx;
  padding-top: 8rpx;
  position: relative;
  z-index: 5;
  display: flex;
  flex-direction: column;
}

.hero-title-line {
  font-size: 56rpx;
  font-weight: 900;
  color: #FFFFFF;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 10rpx rgba(0,30,120,0.2);
  line-height: 1.3;
}

/* ===== 灯塔装饰 ===== */
.lighthouse-wrap {
  position: absolute;
  right: 20rpx;
  top: 140rpx;
  width: 200rpx;
  height: 300rpx;
  z-index: 4;
}

.star-deco {
  position: absolute;
  top: -10rpx;
  right: 20rpx;
  width: 36rpx;
  height: 36rpx;
  background: radial-gradient(circle, #FFE566, #FFCC00);
  border-radius: 4rpx;
  transform: rotate(15deg);
  box-shadow: 0 0 12rpx rgba(255,200,0,0.6);
}

.lighthouse-svg-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 3;
}

.lh-top-glow {
  width: 60rpx;
  height: 40rpx;
  background: radial-gradient(ellipse, rgba(255,230,100,0.6) 0%, transparent 70%);
  margin-bottom: -10rpx;
}

.lh-top {
  width: 70rpx;
  height: 40rpx;
  background: linear-gradient(180deg, #FF8844, #FF6622);
  border-radius: 6rpx 6rpx 0 0;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.lh-lamp {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: radial-gradient(circle, #FFEE88, #FFCC44, #FF9900);
  box-shadow: 0 0 16rpx 6rpx rgba(255,200,0,0.7);
}

.lh-mid {
  width: 88rpx;
  border-radius: 2rpx;
  overflow: hidden;
}

.lh-stripe {
  height: 20rpx;
}

.lh-stripe.white {
  background: #FFFFFF;
}

.lh-stripe.orange {
  background: linear-gradient(90deg, #FF7744, #FF5522);
}

.lh-base {
  width: 100rpx;
  height: 36rpx;
  background: linear-gradient(180deg, #E8F2FF, #D0E4FF);
  border-radius: 0 0 4rpx 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lh-door {
  width: 20rpx;
  height: 24rpx;
  background: #5090D0;
  border-radius: 10rpx 10rpx 0 0;
  margin-top: 12rpx;
}

.lh-platform {
  width: 120rpx;
  height: 16rpx;
  background: linear-gradient(180deg, #CCDDFF, #AACCEE);
  border-radius: 4rpx;
}

/* 橙色装饰球 */
.orange-ball {
  position: absolute;
  right: 10rpx;
  bottom: 40rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, #FFD080, #FF8800);
  box-shadow: 0 4rpx 12rpx rgba(255,140,0,0.4);
}

/* 光晕射线 */
.light-ray {
  position: absolute;
  background: rgba(255,240,160,0.3);
  border-radius: 2rpx;
  z-index: 2;
}

.lr1 {
  width: 180rpx;
  height: 3rpx;
  top: 210rpx;
  right: 80rpx;
  transform: rotate(-25deg);
  transform-origin: right center;
}

.lr2 {
  width: 140rpx;
  height: 2rpx;
  top: 230rpx;
  right: 80rpx;
  transform: rotate(-10deg);
  transform-origin: right center;
}

/* ===== 视频区域 ===== */
.video-wrap {
  margin: -100rpx 24rpx 0;
  position: relative;
  z-index: 10;
}

.video-thumb {
  width: 100%;
  overflow: hidden;
  position: relative;
}

.video-cover {
  width: 100%;
  height: auto;
  display: block;
  /* 图片自带圆角和播放按钮，直接展示原比例 */
}

.video-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.88);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2);
}

.play-icon {
  width: 0;
  height: 0;
  border-top: 20rpx solid transparent;
  border-bottom: 20rpx solid transparent;
  border-left: 32rpx solid #2B7FFF;
  margin-left: 8rpx;
}

/* 底部字幕条 */
.video-caption {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(0deg, rgba(0,0,0,0.55) 0%, transparent 100%);
  padding: 24rpx 24rpx 16rpx;
}

.video-caption-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
}

/* 左上角来源标签 */
.video-source-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: rgba(255,255,255,0.92);
  border-radius: 20rpx;
  padding: 6rpx 16rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.video-source-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B35, #FF9560);
}

.video-source-text {
  font-size: 20rpx;
  color: #333;
  font-weight: 500;
}

/* ===== 金刚区（图片占位） ===== */
.grid-section {
  margin: 28rpx 24rpx 0;
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  align-items: flex-start;
}

/* NEW 徽章 */
.new-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: linear-gradient(135deg, #FF3B30, #FF6060);
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  z-index: 5;
}

.new-badge-text {
  font-size: 20rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 1rpx;
}

/* 编程政策大卡片（左） */
.grid-img-left {
  flex: 0 0 48%;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
}

.grid-img-policy {
  width: 100%;
  height: auto;
  display: block;
}

/* 右侧列 */
.grid-col-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  align-self: stretch;
}

/* 赛考喜报 */
.grid-img-news {
  flex: 0 0 auto;
  border-radius: 16rpx;
  overflow: hidden;
}

/* 底部两个小卡片 */
.grid-row-bottom {
  display: flex;
  flex-direction: row;
  gap: 14rpx;
  flex: 1;
  min-height: 0;
}

.grid-img-xs {
  flex: 1;
  border-radius: 14rpx;
  overflow: hidden;
}

.grid-img-fill {
  width: 100%;
  height: 100%;
  display: block;
}

/* 赛考喜报按自然比例显示，小卡片拉伸填满 */
.grid-img-news image {
  width: 100%;
  height: auto;
}

.grid-img-xs image {
  width: 100%;
  height: 100%;
}

/* ===== 赛事路线规划 主标题 ===== */
.main-section-title {
  padding: 40rpx 24rpx 20rpx;
  text-align: left;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 10rpx;
}

.main-section-text {
  font-size: 44rpx;
  font-weight: 900;
  color: #1A2C5B;
  letter-spacing: 4rpx;
}

.main-section-underline {
  width: 80rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #2B7FFF, #66AAFF);
  border-radius: 3rpx;
}

/* ===== 分类分隔线 ===== */
.cat-divider {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin: 8rpx 24rpx 20rpx;
  gap: 14rpx;
}

.cat-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, rgba(170,190,220,0.3), rgba(170,190,220,0.8));
}

.cat-dot {
  width: 10rpx;
  height: 10rpx;
  background: #4A90D9;
  transform: rotate(45deg);
  flex-shrink: 0;
}

.cat-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A2C5B;
  flex-shrink: 0;
  letter-spacing: 2rpx;
}

/* ===== 赛事卡片 ===== */
.ccard {
  margin: 0 24rpx 20rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(43,100,200,0.07);
  padding: 24rpx 24rpx 20rpx;
}

.ccard-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 22rpx;
  margin-bottom: 16rpx;
}

/* Logo 方块 */
.ccard-logo {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.aice-bg {
  background: linear-gradient(145deg, #E4F2FF, #C8E4FF);
  border: 1.5rpx solid #90C8FF;
}

.gesp-bg {
  background: linear-gradient(145deg, #E4FFE8, #C8F0CC);
  border: 1.5rpx solid #80C880;
}

.ailo-bg {
  background: linear-gradient(145deg, #FFF2E4, #FFD8B8);
  border: 1.5rpx solid #FFAA70;
}

.lq-bg {
  background: linear-gradient(145deg, #E4EEFF, #C8D8FF);
  border: 1.5rpx solid #7890EE;
}

.csp-bg {
  background: linear-gradient(145deg, #F4E4FF, #E0C8FF);
  border: 1.5rpx solid #C070FF;
}

.aicamp-bg {
  background: linear-gradient(145deg, #FFF8E0, #FFEEA8);
  border: 1.5rpx solid #FFD040;
}

.ccard-logo-en {
  font-size: 26rpx;
  font-weight: 900;
  color: #2B7FFF;
  letter-spacing: 1rpx;
}

.gesp-color { color: #2A9A40; }
.ailo-color { color: #E84820; }
.lq-color { color: #1840CC; }
.csp-color { color: #8030CC; }

.ccard-logo-zh {
  font-size: 20rpx;
  font-weight: 800;
  text-align: center;
  line-height: 1.4;
}

.ccard-logo-sm {
  font-size: 18rpx;
  font-weight: 800;
  text-align: center;
  line-height: 1.4;
}

.ccard-logo-img {
  width: 84rpx;
  height: 84rpx;
  display: block;
}

.aicamp-logo {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
}

/* 赛事标题信息 */
.ccard-titles {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.ccard-en {
  font-size: 36rpx;
  font-weight: 800;
  color: #1A2C5B;
  letter-spacing: 2rpx;
}

.ccard-cn {
  font-size: 24rpx;
  color: #7090B0;
  line-height: 1.4;
}

/* 赛事描述 */
.ccard-desc {
  font-size: 26rpx;
  color: #4A5A70;
  line-height: 1.65;
}

/* AI探学营特殊 */
.ai-camp-ccard {
  padding-bottom: 24rpx;
}

.aicamp-cta {
  margin-top: 16rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  gap: 14rpx;
}

.cta-redbox {
  background: linear-gradient(135deg, #EE2222, #FF4444);
  border-radius: 12rpx;
  padding: 8rpx 16rpx;
}

.cta-redbox-text {
  font-size: 22rpx;
  color: #FFD700;
  font-weight: 700;
}

.cta-orangebtn {
  background: linear-gradient(135deg, #FF6B35, #FF9055);
  border-radius: 40rpx;
  padding: 12rpx 32rpx;
}

.cta-btn-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 700;
}

/* ===== 底部占位 ===== */
.page-foot {
  height: 40rpx;
}
