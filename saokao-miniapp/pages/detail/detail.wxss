/* 整体页面 */
.page {
  width: 100%;
  background-color: #F1F6FE;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 顶部 Banner */
.detail-header {
  width: 100%;
  min-height: 380rpx;
  padding: 0 32rpx 40rpx;
  padding-top: var(--status-bar-height, 44rpx);
  position: relative;
  display: flex;
  flex-direction: column;
}

/* 导航栏 */
.nav-bar {
  height: 88rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #FFFFFF;
  border-bottom: 4rpx solid #FFFFFF;
  transform: rotate(45deg);
}

.nav-share {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
  align-items: center;
  padding: 16rpx;
}

.share-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.85);
}

/* 标签 */
.header-tag {
  display: inline-flex;
  background: rgba(255,255,255,0.2);
  border-radius: 8rpx;
  padding: 6rpx 20rpx;
  margin-bottom: 16rpx;
  align-self: flex-start;
}

.header-tag-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* 赛事名称 */
.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

/* 主办方 */
.header-org-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 12rpx;
}

.header-org-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.75);
  flex-shrink: 0;
  padding-top: 2rpx;
}

.header-org-value {
  font-size: 22rpx;
  color: rgba(255,255,255,0.95);
  line-height: 1.5;
  flex: 1;
}

/* 内容区 */
.content {
  padding: 24rpx 24rpx 0;
}

/* section */
.section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 24rpx;
  margin-bottom: 20rpx;
}

.section-title-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 20rpx;
  gap: 12rpx;
}

.section-bar {
  width: 6rpx;
  height: 32rpx;
  border-radius: 3rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.section-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.8;
}

/* 亮点网格 */
.highlights-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.highlight-item {
  width: calc(50% - 8rpx);
  background: #F8F8FC;
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.highlight-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;
}

.highlight-icon {
  font-size: 28rpx;
}

.highlight-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.highlight-desc {
  font-size: 22rpx;
  color: #888;
  line-height: 1.5;
}

/* 赛事安排时间线 */
.schedule-row {
  display: flex;
  flex-direction: row;
  gap: 0;
  align-items: flex-start;
}

.schedule-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.schedule-dot-wrap {
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  position: relative;
  margin-bottom: 8rpx;
}

.schedule-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #DDDDDD;
  flex-shrink: 0;
  z-index: 2;
}

.schedule-item.done .schedule-dot,
.schedule-item.active .schedule-dot {
  background: #694EF0;
}

.schedule-item.active .schedule-dot {
  box-shadow: 0 0 0 4rpx rgba(105, 78, 240, 0.3);
}

.schedule-line {
  position: absolute;
  right: -50%;
  top: 50%;
  transform: translateY(-50%);
  width: 100%;
  height: 2rpx;
  background: #DDDDDD;
  z-index: 1;
}

.schedule-item.done .schedule-line {
  background: #694EF0;
}

.schedule-badge {
  background: #F0EDFF;
  border-radius: 12rpx;
  padding: 8rpx 12rpx;
  min-width: 80rpx;
  text-align: center;
}

.schedule-item.done .schedule-badge,
.schedule-item.active .schedule-badge {
  background: #694EF0;
}

.schedule-label {
  font-size: 20rpx;
  color: #999;
  text-align: center;
  white-space: pre-wrap;
}

.schedule-item.done .schedule-label,
.schedule-item.active .schedule-label {
  color: #FFFFFF;
}

.schedule-sublabel {
  font-size: 20rpx;
  color: #666;
  text-align: center;
  margin-top: 8rpx;
  white-space: pre-wrap;
}

/* 报名信息卡片 */
.info-card {
  background: #F8F8FC;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 12rpx;
}

.info-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.info-text {
  font-size: 26rpx;
  color: #444;
  line-height: 1.6;
  flex: 1;
}

/* 底部报名按钮 */
.footer-btn-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}

.footer-btn {
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.footer-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

/* 分享遮罩 */
.share-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}

/* 分享底部弹窗 */
.share-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.share-sheet.show {
  transform: translateY(0);
}

.share-sheet-title {
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 40rpx;
}

.share-options {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  margin-bottom: 40rpx;
}

.share-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.share-option-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-option-emoji {
  font-size: 44rpx;
}

.share-option-label {
  font-size: 24rpx;
  color: #555;
}

.share-cancel {
  text-align: center;
  font-size: 30rpx;
  color: #999;
  padding: 20rpx 0;
  border-top: 1rpx solid #F0F0F0;
}
