/* 整体页面 */
.page {
  width: 100%;
  background-color: #F1F6FE;
  padding-bottom: 40rpx;
}

/* 导航栏 */
.nav-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  padding-top: var(--status-bar-height, 44rpx);
  z-index: 10;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  width: 20rpx;
  height: 36rpx;
}

.nav-dots {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
  align-items: center;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.8);
}

/* 头部 Banner */
.header-banner {
  width: 100%;
  min-height: 480rpx;
  background: linear-gradient(180deg, #694EF0 0%, #8B6FF0 50%, #A855F7 80%, #C084FC 100%);
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
  padding-bottom: 0;
}

/* 装饰星星 */
.star {
  position: absolute;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 50%;
}

.star-1 {
  width: 12rpx;
  height: 12rpx;
  top: 120rpx;
  left: 60rpx;
}

.star-2 {
  width: 8rpx;
  height: 8rpx;
  top: 180rpx;
  right: 80rpx;
}

.star-3 {
  width: 16rpx;
  height: 16rpx;
  top: 200rpx;
  left: 140rpx;
}

/* 年份徽章 */
.year-badge {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: rgba(255,255,255,0.15);
  border-radius: 40rpx;
  padding: 8rpx 32rpx;
  margin-bottom: 16rpx;
}

.year-decor {
  font-size: 28rpx;
  color: #FFD700;
  font-weight: bold;
}

.year-text {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 700;
  margin: 0 12rpx;
}

/* 横幅标题 */
.banner-title {
  font-size: 64rpx;
  font-weight: 900;
  color: #FFFFFF;
  letter-spacing: 8rpx;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.3);
  margin-bottom: 24rpx;
  position: relative;
  z-index: 2;
}

/* 吉祥物区域 */
.mascot-area {
  position: relative;
  width: 320rpx;
  height: 320rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.mascot-glow {
  position: absolute;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 260rpx;
  height: 100rpx;
  background: rgba(255, 200, 0, 0.3);
  border-radius: 50%;
  filter: blur(20rpx);
}

.mascot-img {
  width: 260rpx;
  height: 280rpx;
  position: relative;
  z-index: 2;
}

/* 勋章 */
.medal {
  position: absolute;
  z-index: 3;
}

.medal-1 {
  top: 20rpx;
  right: -20rpx;
}

.medal-2 {
  top: 60rpx;
  left: -20rpx;
}

.medal-inner {
  background: linear-gradient(135deg, #FFD700, #FFA500);
  border-radius: 50%;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255,165,0,0.4);
}

.medal-icon {
  font-size: 28rpx;
}

.medal-text {
  font-size: 18rpx;
  color: #FFF;
  font-weight: bold;
}

/* 说明文字 */
.intro-text {
  margin: 24rpx 32rpx;
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

/* 赛事列表 */
.contest-list {
  padding: 0 24rpx;
}

/* 赛事卡片 */
.contest-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

/* 标签条 */
.card-tag-bar {
  width: 100%;
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-tag-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

/* 赛事名称 */
.card-name-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 24rpx 24rpx 12rpx;
  gap: 16rpx;
}

.card-icon-wrap {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-icon-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
}

.card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  line-height: 1.5;
  flex: 1;
}

/* 信息行 */
.card-info-row {
  padding: 4rpx 24rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.card-info-label {
  font-size: 24rpx;
  color: #666;
  flex-shrink: 0;
}

.card-info-value {
  font-size: 24rpx;
  color: #333;
  flex: 1;
  line-height: 1.6;
}

/* 赛事安排 */
.card-schedule-title {
  padding: 12rpx 24rpx 8rpx;
  font-size: 24rpx;
  color: #666;
}

.card-schedule-row {
  display: flex;
  flex-direction: row;
  padding: 8rpx 24rpx 24rpx;
  gap: 0;
  align-items: flex-start;
}

.schedule-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

/* 连接线和圆点 */
.schedule-dot-wrap {
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  position: relative;
  margin-bottom: 8rpx;
}

.schedule-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #DDDDDD;
  flex-shrink: 0;
  z-index: 2;
}

.schedule-item.done .schedule-dot {
  background: #694EF0;
}

.schedule-item.active .schedule-dot {
  background: #694EF0;
  box-shadow: 0 0 0 4rpx rgba(105, 78, 240, 0.3);
}

.schedule-line {
  position: absolute;
  right: -50%;
  top: 50%;
  transform: translateY(-50%);
  width: 100%;
  height: 2rpx;
  background: #DDDDDD;
  z-index: 1;
}

.schedule-item.done .schedule-line {
  background: #694EF0;
}

/* 时间胶囊 */
.schedule-badge {
  background: #F0EDFF;
  border-radius: 12rpx;
  padding: 8rpx 12rpx;
  min-width: 80rpx;
  text-align: center;
}

.schedule-item.done .schedule-badge,
.schedule-item.active .schedule-badge {
  background: #694EF0;
}

.schedule-label {
  font-size: 20rpx;
  color: #999;
  text-align: center;
  white-space: pre-wrap;
}

.schedule-item.done .schedule-label,
.schedule-item.active .schedule-label {
  color: #FFFFFF;
}

.schedule-sublabel {
  font-size: 20rpx;
  color: #666;
  text-align: center;
  margin-top: 8rpx;
  white-space: pre-wrap;
}

/* 页脚注 */
.footer-note {
  text-align: center;
  padding: 16rpx 0 32rpx;
  font-size: 24rpx;
  color: #999;
}
